# ============================================================================
# nexus-command .gitignore
# Owner: Cary Hebert | github.com/chebe24
# Philosophy: Allowlist only. If the extension isn't on the list, it doesn't
#             get in. Credentials, binaries, and OS noise never touch this repo.
# Last Updated: 2026-03-10
# ============================================================================


# ====================
# BLOCK EVERYTHING BY DEFAULT
# ====================

# Deny all files — only explicitly allowed extensions get through.
# This is an allowlist model: safe by default, opt-in per extension.
*.*


# ====================
# ALLOWLIST — permitted extensions only
# ====================

# Google Apps Script & Web
!*.gs
!*.js
!*.ts
!*.html
!*.css

# Data & Config
!*.json
!*.yaml
!*.yml
!*.toml
!*.xml

# Python
!*.py

# Shell
!*.sh

# Documentation
!*.md
!*.txt

# Git internals
!.gitignore
!.gitkeep
!.gitmodules

# Clasp project files (selective — only named files, not all .json)
!dev-project/.clasp.json
!prod-project/.clasp.json


# ====================
# ALLOW DIRECTORIES
# (Git must be able to traverse folders)
# ====================

!*/


# ====================
# RE-BLOCK — dangerous files that must never enter regardless
# ====================

# Executables & installers
*.exe
*.dmg
*.pkg
*.app
*.bin
*.deb
*.rpm
*.msi
*.iso

# Scripts that could run on Windows/Linux systems
*.bat
*.cmd
*.ps1
*.vbs

# Compiled / binary
*.o
*.so
*.dll
*.class
*.pyc
*.pyo
__pycache__/

# Credentials & secrets (belt-and-suspenders)
.env
.env.*
*.env
.clasprc.json
.clasprc.json.bak
claude_desktop_config.json
.claude.json

# Backup & stale files
*.bak
*.backup
*.old
*.orig
*.tmp
*.temp
*_old.*
*_backup.*
*_draft.*
*_temp.*

# macOS ghost files
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.TemporaryItems
.Trashes
.fseventsd

# iCloud placeholders
*.icloud
.icloud
**/*.icloud
*.nosync

# IDE & editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# Dependencies & build output
node_modules/
dist/
build/
.cache/
.parcel-cache/

# Logs
*.log
logs/

# Office & binary docs (belong in Google Drive, not Git)
*.xlsx
*.xls
*.docx
*.doc
*.pptx
*.ppt
*.pdf

# Database exports (may contain PII)
db/*.csv
db/*.xlsx

# RAG engine artifacts
standards_chroma/
standards_raw/

# Archive and deprecated folder contents
archive/**/*
!archive/.gitkeep
deprecated/**/*
!deprecated/.gitkeep


# ====================
# NOTES FOR FUTURE CARY
# ====================
#
# To evict a .DS_Store already committed:
#   git rm --cached .DS_Store
#   git rm --cached **/.DS_Store
#   git commit -m "chore: remove tracked .DS_Store files"
#
# To remove a stale config file already committed:
#   git rm --cached dev-project/Config_old.gs
#   git commit -m "security: remove stale config file from tracking"
#
# Stale branch cleanup (run monthly):
#   git branch -r | grep -v 'main' | grep -v HEAD
#   git push origin --delete <branch-name>
#
# Git reflog cleanup (before major pushes):
#   git gc --prune=now --aggressive
#
# To check what files WOULD be ignored before committing:
#   git status
#   git check-ignore -v <filename>
# ============================================================================
LoggerAgent/venv/
02_Projects/
LoggerAgent/
##-*
LoggerAgent/venv/
02_Projects/
LoggerAgent/
##-*
logger-agent/data/
logger-agent/logs/
logger-agent/venv/
